{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A user project containing generated images",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["id", "name", "createdAt", "userId"]
    },
    "HistoryItem": {
      "title": "History Item",
      "description": "An image generated by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "prompt": { "type": "string" },
        "timestamp": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["id", "url", "prompt", "timestamp", "userId"]
    },
    "PromptCategory": {
      "title": "Prompt Category",
      "description": "A category containing multiple prompts",
      "type": "object",
      "properties": {
        "category": { "type": "string" },
        "prompts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "prompt": { "type": "string" }
            },
            "required": ["title", "prompt"]
          }
        },
        "userId": { "type": "string" }
      },
      "required": ["category", "prompts", "userId"]
    },
    "SupportTicket": {
      "title": "Support Ticket",
      "description": "A support ticket created by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "in-progress", "resolved", "closed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "createdAt": { "type": "number" },
        "userId": { "type": "string" },
        "userName": { "type": "string" }
      },
      "required": ["id", "title", "description", "status", "priority", "createdAt", "userId", "userName"]
    }
  },
  "firestore": {
    "/users/{userId}/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "User's projects"
    },
    "/users/{userId}/projects/{projectId}/history/{historyId}": {
      "schema": { "$ref": "#/entities/HistoryItem" },
      "description": "User's generated image history for a specific project"
    },
    "/users/{userId}/promptBank/{categoryId}": {
      "schema": { "$ref": "#/entities/PromptCategory" },
      "description": "User's custom prompt bank categories"
    },
    "/users/{userId}/supportTickets/{ticketId}": {
      "schema": { "$ref": "#/entities/SupportTicket" },
      "description": "User's support tickets"
    }
  }
}
